/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self' https://marbl.codes; script-src 'self' https://marbl.codes https://cdnjs.cloudflare.com https://unpkg.com https://cdn.usefathom.com; style-src 'self' https://marbl.codes https://fonts.googleapis.com https://unpkg.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://marbl.codes https://subscribe.marbl.codes data:; media-src 'self'; connect-src 'self' https://github-stats.marbl-codes.workers.dev https://cdn.usefathom.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate
